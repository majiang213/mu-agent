{
  "name": "mu-agent",
  "version": "1.0.0",
  "description": "µagent — small-model coding agent with deterministic pipelines",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mu-agent": "./src/cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "rebuild": "rimraf dist && tsc",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ]
  },
  "keywords": [
    "agent",
    "llm",
    "coding"
  ],
  "author": "MJ",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/stopword": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.1",
    "@sinclair/typebox": "^0.27.10",
    "@earendil-works/pi-ai": "^0.78.1",
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@earendil-works/pi-tui": "^0.78.1",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.10.0",
    "commander": "^15.0.0",
    "deepmerge": "^4.3.1",
    "glob": "^13.0.6",
    "gpt-tokenizer": "^3.4.0",
    "node-html-markdown": "^2.0.0",
    "stopword": "^3.1.5",
    "vscode-jsonrpc": "^9.0.0",
    "wink-bm25-text-search": "^3.1.2"
  }
}
