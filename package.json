{
  "name": "mu-agent",
  "version": "1.0.0",
  "description": "µagent — small-model coding agent with deterministic pipelines",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mu-agent": "./src/cli.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "rebuild": "rimraf dist && tsc",
    "test": "vitest run",
    "dev": "tsx src/cli.ts",
    "cli": "tsx src/cli.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepare": "husky && patch-package",
    "postinstall": "patch-package"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "prettier --write"
    ]
  },
  "keywords": [
    "agent",
    "llm",
    "coding"
  ],
  "author": "MJ",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.4",
    "@types/stopword": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "patch-package": "^8.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.58.4",
    "@mariozechner/pi-ai": "^0.58.4",
    "@mariozechner/pi-coding-agent": "^0.58.4",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "commander": "^14.0.3",
    "deepmerge": "^4.3.1",
    "glob": "^11.0.0",
    "gpt-tokenizer": "^3.4.0",
    "lodash-es": "^4.18.1",
    "node-html-markdown": "^2.0.0",
    "stopword": "^3.1.5",
    "vscode-jsonrpc": "^8.2.1",
    "wink-bm25-text-search": "^3.1.2"
  }
}
